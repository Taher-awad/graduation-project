flowchart TD
    Start([Start Task]) --> Download["Download from S3"]
    Download --> IsZip{"Is File .ZIP?"}

    %% Extraction & Discovery Phase
    IsZip -- Yes --> Extract["Extract Archive"]
    Extract --> FindMain["Find Main Model File<br/>(.blend, .gltf, .fbx, .obj)"]
    FindMain --> FoundMain{Found?}
    
    FoundMain -- No --> SearchNested["Search Nested ZIPs"]
    SearchNested --> FoundNested{"Found Nested?"}
    FoundNested -- Yes --> ExtractNested["Extract Nested & Retry"]
    ExtractNested --> FindMain
    
    FoundNested -- No --> Error["Error: No Model Found"]
    FoundMain -- Yes --> SetCWD["Set CWD to Model Dir<br/>(For Relative Textures)"]
    IsZip -- No --> SetPath["Set Path to File"]

    %% Blender Phase
    SetCWD --> Blender[["Run Blender 3.6<br/>(process_model.py)"]]
    SetPath --> Blender

    subgraph Blender_Process [Blender Python Pipeline]
        direction TB
        B_Start(Load Scene) --> B_AutoSmooth["Fix: Enable Auto Smooth"]
        B_AutoSmooth --> B_Relink["Smart Texture Relinking<br/>(Scan Dir for Matches)"]
        B_Relink --> B_SpecGloss["Fix: Convert Spec/Gloss<br/>to Principled BSDF"]
        B_SpecGloss --> B_Trans["Fix: Transparency<br/>(Leaves->Hashed, Glass->Blend)"]
        B_Trans --> B_Valid{"Validate<br/>Geometry?"}
        
        B_Valid -- Fail --> B_Err[Return VALIDATION_FAILED]
        B_Valid -- Pass --> B_Norm["Normalize<br/>(Scale/Center/Parent)"]
        B_Norm --> B_Export["Export to GLB"]
    end

    Blender --> Result{"Blender Success?"}
    
    Result -- No --> Error
    Result -- Yes --> Optimize["Optimization (Optional)"]
    Optimize --> Upload["Upload GLB to S3"]
    Upload --> UpdateDB["Update DB: COMPLETED"]
    UpdateDB --> End([End Task])

    Error --> UpdateFail["Update DB: FAILED"]
    UpdateFail --> End

    style Blender_Process fill:#f5f5f5,stroke:#333,stroke-dasharray: 5 5
    style Error fill:#ffcdd2,stroke:#b71c1c
    style B_Err fill:#ffcdd2,stroke:#b71c1c
    style UpdateDB fill:#c8e6c9,stroke:#2e7d32
