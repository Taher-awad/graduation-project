graph TB
    subgraph Host["Host Machine"]
        user[User Browser]
        unity[Unity Client]
    end

    subgraph Docker["Docker Network"]
        direction TB
        api[cortex_api:8000]
        worker[cortex_worker]
        minio[cortex_minio:9000]
        
        subgraph Data["Persistence Layer"]
            direction LR
            db[cortex_db:5432]
            redis[cortex_redis:6379]
        end
    end

    %% User Connections
    user ==>|HTTP:8000| api
    user ==>|HTTP:9000| minio

    %% Unity Connections
    unity ==>|HTTP:8000| api
    unity ==>|HTTP:9000| minio

    %% API Connections
    api -->|SQL| db
    api -->|Celery Task| redis
    api -->|S3 Put| minio

    %% Worker Connections
    worker -->|Celery Get| redis
    worker -->|S3 Get/Put| minio
    worker -->|SQL Update| db

    %% Layout Helpers (Invisible links to separate columns if needed)
    api ~~~ worker

    %% Styling
    style api fill:#e1f5fe,stroke:#01579b
    style worker fill:#e1f5fe,stroke:#01579b
    style db fill:#fff9c4,stroke:#fbc02d
    style redis fill:#ffe0b2,stroke:#f57c00
    style minio fill:#e0f2f1,stroke:#00695c
